# =========================
# GOOGLE API
# =========================
GOOGLE_API_KEY=key
GOOGLE_CLIENT_ID=id
GOOGLE_CLIENT_SECRET=
SITE_DOMAIN=localhost:8000

# =========================
# APP SETTINGS
# =========================
CACHE_TTL_HOURS=72

# =========================
# LIMITS
# =========================
MAX_GOOGLE_CALLS_PER_DAY=500
ANON_DAILY_LIMIT=3
FREE_DAILY_LIMIT=30
PREMIUM_DAILY_LIMIT=200
SEARCH_THROTTLE_RATE=8

# =========================
# SECURITY
# =========================
CSRF_TRUSTED_ORIGINS=http://localhost:8000
TURNSTILE_SITE_KEY=0x
TURNSTILE_SECRET_KEY=0x
TRUST_X_FORWARDED_FOR=True

# =========================
# TELEGRAM NOTIFICATIONS
# =========================
TELEGRAM_BOT_TOKEN=token
TELEGRAM_CHAT_ID=id

# =========================
# EMAIL FALLBACK
# =========================
DEFAULT_FROM_EMAIL=no-reply@example.com
CONTACT_FALLBACK_EMAIL=admin@example.com

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# =========================
# AI
# =========================
AI_ENABLED=True
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=sk-
AI_REQUEST_TIMEOUT=15
MAX_AI_SUMMARIES_PER_DAY=200
AI_PROMPT_VERSION=v1
