DJANGO_ADMIN_URL=backoffice
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=1234
SITE_DOMAIN=localhost:8000
TRUST_X_FORWARDED_FOR=True

# =========================
# DATABASE
# =========================
POSTGRES_DB=dealerfinder
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# =========================
# REDIS / CACHE
# =========================
REDIS_URL=redis://redis:6379/0
CACHE_TTL_HOURS=72

AI_SUMMARY_CACHE_TTL_SECONDS=21600
PLACE_DETAILS_CACHE_TTL_SECONDS=86400

AI_DEDUP_LOCK_TTL_SECONDS=60
GOOGLE_PLACE_DETAILS_LOCK_TTL_SECONDS=20
GOOGLE_PLACE_DETAILS_LOCK_WAIT_ATTEMPTS=10
GOOGLE_PLACE_DETAILS_LOCK_WAIT_SLEEP_SECONDS=0.2

# =========================
# GOOGLE / SEARCH
# =========================
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

MAX_GOOGLE_CALLS_PER_DAY=500
SEARCH_THROTTLE_RATE=8

# =========================
# SEARCH QUOTAS
# =========================
ANON_DAILY_LIMIT=5
FREE_DAILY_LIMIT=15
PREMIUM_DAILY_LIMIT=50

# =========================
# AI / PROVIDER
# =========================
AI_ENABLED=True
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=your_openai_api_key
AI_REQUEST_TIMEOUT=15
AI_RATE_LIMIT_PER_MINUTE=5

AI_PROMPT_VERSION=v1
AI_SYNC_ON_SEARCH=False
AI_SYNC_LIMIT=2

AI_SUMMARY_TTL_DAYS=7
AI_FAILED_RETRY_HOURS=12
AI_PENDING_STALE_MINUTES=30
MAX_AI_SUMMARIES_PER_DAY=200

# =========================
# AI QUOTAS
# =========================
ANON_AI_DAILY_LIMIT=3
FREE_AI_DAILY_LIMIT=15
PREMIUM_AI_DAILY_LIMIT=50

# =========================
# FEATURE FLAGS
